/**
 * Classic Raytracer Demo Scene
 *
 * Recreates the reference image:
 *   - Black background
 *   - Reflective water plane with concentric ripples
 *   - 4 spheres: silver (left), pink (center-left), dark red (right), teal (center-bottom)
 *   - Orange/red triangle in the center
 *   - Perspective camera looking slightly down
 *
 * Features:
 *   - Perspective camera
 *   - ShadowTracer with reflections
 *   - Jittered sampler (anti-aliasing)
 *   - Mirror material for water + silver sphere
 *   - Phong material for triangle and colored spheres
 *   - BVH acceleration
 */

#include "../cameras/Perspective.hpp"

#include "../geometry/Plane.hpp"
#include "../geometry/Sphere.hpp"
#include "../geometry/Triangle.hpp"

#include "../materials/Matte.hpp"
#include "../materials/Phong.hpp"
#include "../materials/Mirror.hpp"

#include "../samplers/Jittered.hpp"

#include "../light/PointLight.hpp"
#include "../light/DirectionalLight.hpp"

#include "../tracers/Shadow.hpp"

#include "../acceleration/BVH.hpp"

#include "../utilities/Constants.hpp"

#include "../world/World.hpp"

#include <cmath>

void World::build(void) {

    // ── VIEW PLANE ──────────────────────────────
    vplane.top_left     = Point3D(-200, 150, 100);
    vplane.bottom_right = Point3D( 200,-150, 100);
    vplane.hres = 640;
    vplane.vres = 480;

    bg_color = RGBColor(0.0f, 0.0f, 0.0f);  // pure black background

    // ── CAMERA ──────────────────────────────────
    set_camera(new Perspective(Point3D(0, 80, 500)));

    // ── SAMPLER ─────────────────────────────────
    sampler_ptr = new Jittered(camera_ptr, &vplane, 3);  // 9 samples/pixel

    // ── TRACER ──────────────────────────────────
    tracer_ptr = new ShadowTracer(this);

    // ── MATERIALS ───────────────────────────────

    // Water/floor — highly reflective mirror with blue tint
    Material* water_mat = new Mirror(0.90f, RGBColor(0.55f, 0.75f, 1.0f));

    // Silver sphere (left) — near-perfect chrome mirror
    Material* silver_mat = new Mirror(0.88f, RGBColor(0.9f, 0.92f, 1.0f));

    // Pink/lavender sphere (center-left)
    Material* pink_mat = new Phong(RGBColor(0.85f, 0.55f, 0.75f), 0.5f, 0.8f, 150.0f, 0.15f);

    // Dark red sphere (right)
    Material* red_mat = new Phong(RGBColor(0.55f, 0.08f, 0.12f), 0.5f, 0.7f, 200.0f, 0.12f);

    // Teal sphere (center, sitting at base of triangle)
    Material* teal_mat = new Phong(RGBColor(0.05f, 0.55f, 0.65f), 0.5f, 0.85f, 250.0f, 0.18f);

    // Orange/red triangle
    Material* tri_mat = new Phong(RGBColor(0.95f, 0.50f, 0.10f), 0.7f, 0.4f, 60.0f, 0.1f);

    // ── WATER PLANE — sine ripple triangle mesh ──
    {
        const float water_y = -60.0f;
        const float A       =  5.5f;
        const float freq    =  0.055f;
        const int   W       =  100;
        const int   D       =  100;
        const float x0 = -300.0f, x1 = 300.0f;
        const float z0 = -300.0f, z1 = 50.0f;
        const float dx = (x1 - x0) / W;
        const float dz = (z1 - z0) / D;

        auto ripple = [&](float x, float z) -> float {
            float r = sqrtf(x * x + z * z);
            return water_y + A * sinf(freq * r);
        };

        for (int ix = 0; ix < W; ix++) {
            for (int iz = 0; iz < D; iz++) {
                float xa = x0 + ix * dx, xb = xa + dx;
                float za = z0 + iz * dz, zb = za + dz;

                Point3D p00(xa, ripple(xa, za), za);
                Point3D p10(xb, ripple(xb, za), za);
                Point3D p01(xa, ripple(xa, zb), zb);
                Point3D p11(xb, ripple(xb, zb), zb);

                Triangle* t1 = new Triangle(p00, p10, p11);
                t1->set_material(water_mat);
                add_geometry(t1);

                Triangle* t2 = new Triangle(p00, p11, p01);
                t2->set_material(water_mat);
                add_geometry(t2);
            }
        }
    }

    // ── TRIANGLE ────────────────────────────────
    {
        Point3D apex  (  0,  130, -80);
        Point3D base_l(-110, -60, -80);
        Point3D base_r( 110, -60, -80);

        Triangle* tri = new Triangle(base_l, base_r, apex);
        tri->set_material(tri_mat);
        add_geometry(tri);

        Triangle* tri_back = new Triangle(base_r, base_l, apex);
        tri_back->set_material(tri_mat);
        add_geometry(tri_back);
    }

    // ── SPHERES ─────────────────────────────────
    const float water_y = -60.0f;

    // Silver sphere — left
    {
        float r = 70.0f;
        Sphere* s = new Sphere(Point3D(-170, water_y + r * 0.55f, -80), r);
        s->set_material(silver_mat);
        add_geometry(s);
    }

    // Pink sphere — center-left
    {
        float r = 58.0f;
        Sphere* s = new Sphere(Point3D(-60, water_y + r * 0.6f, -60), r);
        s->set_material(pink_mat);
        add_geometry(s);
    }

    // Dark red sphere — right
    {
        float r = 62.0f;
        Sphere* s = new Sphere(Point3D(165, water_y + r * 0.55f, -80), r);
        s->set_material(red_mat);
        add_geometry(s);
    }

    // Teal sphere — center-bottom, at triangle base
    {
        float r = 36.0f;
        Sphere* s = new Sphere(Point3D(0, water_y + r * 0.65f, -50), r);
        s->set_material(teal_mat);
        add_geometry(s);
    }

    // ── LIGHTS ──────────────────────────────────

    // Main key light — warm white, above-right
    add_light(new PointLight(
        Point3D(150, 300, 200),
        RGBColor(1.0f, 0.95f, 0.85f),
        3.5f
    ));

    // Fill light — cool blue, from the left
    add_light(new PointLight(
        Point3D(-200, 200, 100),
        RGBColor(0.6f, 0.7f, 1.0f),
        2.0f
    ));

    // Rim light — from behind objects
    add_light(new PointLight(
        Point3D(0, 100, -300),
        RGBColor(0.8f, 0.6f, 0.9f),
        2.5f
    ));

    // ── BVH ACCELERATION ────────────────────────
    accel_ptr = new BVH(geometry);
    use_acceleration = true;
}